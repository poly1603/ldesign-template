{
  "name": "@ldesign/template",
  "version": "1.0.0",
  "description": "一个强大的模板库，支持多种模板类型、模板缓存和模板错误处理",
  "type": "module",
  "main": "./lib/index.js",
  "module": "./es/index.js",
  "types": "./types/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./es/index.js",
      "require": "./lib/index.js",
      "types": "./types/index.d.ts"
    },
    "./decorators": {
      "import": "./es/decorators.js",
      "require": "./lib/decorators.js",
      "types": "./types/decorators.d.ts"
    },
    "./plugins/persist": {
      "import": "./es/plugins/persist.js",
      "require": "./lib/plugins/persist.js",
      "types": "./types/plugins/persist.d.ts"
    },
    "./plugins/cache": {
      "import": "./es/plugins/cache.js",
      "require": "./lib/plugins/cache.js",
      "types": "./types/plugins/cache.d.ts"
    },
    "./store-class": {
      "import": "./es/store-class.js",
      "require": "./lib/store-class.js",
      "types": "./types/store-class.d.ts"
    },
    "./types": {
      "import": "./es/types.js",
      "require": "./lib/types.js",
      "types": "./types/types.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "README.md",
    "dist",
    "es",
    "lib",
    "types"
  ],
  "scripts": {
    "dev": "rollup -c -w",
    "build": "rollup -c && npm run build:types",
    "build:types": "tsc --declaration --emitDeclarationOnly --outDir dist/types",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts,.vue",
    "lint:fix": "eslint src --ext .ts,.vue --fix",
    "format": "prettier --write src/**/*.{ts,vue,json}",
    "format:check": "prettier --check src/**/*.{ts,vue,json}",
    "docs": "typedoc src/index.ts",
    "docs:serve": "typedoc src/index.ts --watch --serve",
    "prepare": "npm run build",
    "prepublishOnly": "npm run test && npm run lint && npm run build"
  },
  "keywords": [
    "vue",
    "vue3",
    "pinia",
    "state-management",
    "typescript",
    "reactive",
    "store",
    "ldesign"
  ],
  "author": "LDesign Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/poly1603/ldesign-store.git"
  },
  "bugs": {
    "url": "https://github.com/poly1603/ldesign-store/issues"
  },
  "homepage": "https://github.com/poly1603/ldesign-store#readme",
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "dependencies": {
    "@vue/reactivity": "^3.3.4",
    "@vue/runtime-core": "^3.3.4"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-json": "^6.0.1",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.5",
    "@types/node": "^20.8.0",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "@vitejs/plugin-vue": "^4.4.0",
    "@vitest/coverage-v8": "^0.34.6",
    "@vitest/ui": "^0.34.6",
    "@vue/compiler-sfc": "^3.3.4",
    "eslint": "^8.50.0",
    "eslint-plugin-vue": "^9.17.0",
    "prettier": "^3.0.3",
    "rollup": "^3.29.0",
    "rollup-plugin-dts": "^6.2.1",
    "rollup-plugin-vue": "^6.0.0",
    "tslib": "^2.6.2",
    "typedoc": "^0.25.2",
    "typescript": "^5.2.2",
    "vitest": "^0.34.6"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "commit-msg": "pnpm tsx scripts/validate-commit-msg.ts",
      "pre-push": "pnpm test:run"
    }
  },
  "lint-staged": {
    "*.{ts,tsx,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,json,yml,yaml}": [
      "prettier --write"
    ]
  }
}
